{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sponsoredai.dev/schemas/wait-state-event.schema.json",
  "title": "SAI Public Wait-State Event",
  "description": "Sanitized wait-state metadata before placement-specific transport identifiers are attached.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "surface": {
      "type": "string",
      "enum": ["cli_agent_wait", "desktop_overlay"]
    },
    "tool": {
      "type": "string",
      "enum": ["codex", "claude", "run", "desktop_overlay"]
    },
    "event": {
      "type": "string",
      "enum": ["agent_thinking", "command_wait", "rendered", "qualified_5s"]
    },
    "duration_bucket": {
      "type": "string",
      "enum": ["0-10s", "10-30s", "30-120s", "120s+"]
    },
    "terminal_interactive": {
      "type": "boolean"
    },
    "attended_interactive": {
      "type": "boolean"
    },
    "ci": {
      "type": "boolean"
    },
    "country": {
      "type": "string"
    },
    "code_uploaded": {
      "type": "boolean",
      "const": false
    },
    "prompt_uploaded": {
      "type": "boolean",
      "const": false
    },
    "logs_uploaded": {
      "type": "boolean",
      "const": false
    }
  },
  "required": [
    "code_uploaded",
    "prompt_uploaded",
    "logs_uploaded"
  ]
}
