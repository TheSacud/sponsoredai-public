{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sponsoredai.dev/schemas/placement-event.schema.json",
  "title": "SAI Public Placement Event",
  "description": "Allowlisted event fields that can cross the SAI privacy boundary for sponsor placement accounting.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "surface": {
      "type": "string",
      "enum": ["cli_agent_wait", "desktop_overlay"],
      "description": "The local surface where the placement was shown."
    },
    "tool": {
      "type": "string",
      "enum": ["codex", "claude", "run", "desktop_overlay"],
      "description": "The coarse tool/surface label, such as codex, claude, or desktop_overlay."
    },
    "event": {
      "type": "string",
      "enum": ["rendered", "qualified_5s", "click"],
      "description": "Placement lifecycle event, such as rendered or qualified_5s."
    },
    "duration_bucket": {
      "type": "string",
      "enum": ["0-10s", "10-30s", "30-120s", "120s+"],
      "description": "Coarse wait-duration bucket, not terminal output."
    },
    "visible_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "Coarse placement visibility duration, not screen content."
    },
    "terminal_interactive": {
      "type": "boolean",
      "description": "Terminal-surface attendance attestation."
    },
    "attended_interactive": {
      "type": "boolean",
      "description": "Desktop-overlay attendance attestation."
    },
    "ci": {
      "type": "boolean",
      "description": "True when the run is CI/headless and should not qualify."
    },
    "country": {
      "type": "string",
      "description": "Approximate country code when available."
    },
    "code_uploaded": {
      "type": "boolean",
      "const": false
    },
    "prompt_uploaded": {
      "type": "boolean",
      "const": false
    },
    "logs_uploaded": {
      "type": "boolean",
      "const": false
    },
    "install_id_hash": {
      "type": "string",
      "description": "Opaque installation hash."
    },
    "cli_version": {
      "type": "string",
      "description": "SAI CLI version."
    },
    "session_id": {
      "type": "string",
      "description": "Opaque local session identifier."
    },
    "placement_id": {
      "type": "string",
      "description": "Opaque backend-issued placement identifier."
    },
    "campaign_id": {
      "type": "string",
      "description": "Opaque campaign identifier."
    },
    "signature": {
      "type": "string",
      "description": "Opaque event signature or token."
    },
    "click_token": {
      "type": "string",
      "description": "Opaque click token, present only for click attribution flows."
    }
  },
  "required": [
    "code_uploaded",
    "prompt_uploaded",
    "logs_uploaded"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "surface": { "const": "desktop_overlay" } },
        "required": ["surface"]
      },
      "then": {
        "required": ["attended_interactive"]
      }
    },
    {
      "if": {
        "properties": { "surface": { "const": "cli_agent_wait" } },
        "required": ["surface"]
      },
      "then": {
        "required": ["terminal_interactive"]
      }
    }
  ]
}
