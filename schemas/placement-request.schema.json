{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sponsoredai.dev/schemas/placement-request.schema.json",
  "title": "SAI Public Placement Request",
  "description": "Public shape of the privacy-safe metadata a client can use when asking for an eligible placement. This intentionally omits credentials, headers, signature derivation, ranking, caps, and anti-abuse internals.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "surface": {
      "type": "string",
      "enum": ["cli_agent_wait", "desktop_overlay"]
    },
    "tool": {
      "type": "string",
      "enum": ["codex", "claude", "run", "desktop_overlay"]
    },
    "event": {
      "type": "string",
      "enum": ["agent_thinking", "command_wait"]
    },
    "duration_bucket": {
      "type": "string",
      "enum": ["0-10s", "10-30s", "30-120s", "120s+"]
    },
    "terminal_interactive": {
      "type": "boolean"
    },
    "attended_interactive": {
      "type": "boolean"
    },
    "ci": {
      "type": "boolean"
    },
    "country": {
      "type": "string"
    },
    "code_uploaded": {
      "type": "boolean",
      "const": false
    },
    "prompt_uploaded": {
      "type": "boolean",
      "const": false
    },
    "logs_uploaded": {
      "type": "boolean",
      "const": false
    },
    "install_id_hash": {
      "type": "string",
      "description": "Opaque installation hash."
    },
    "cli_version": {
      "type": "string"
    },
    "session_id": {
      "type": "string",
      "description": "Opaque session identifier."
    }
  },
  "required": [
    "surface",
    "tool",
    "code_uploaded",
    "prompt_uploaded",
    "logs_uploaded"
  ]
}
