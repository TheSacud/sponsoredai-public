# Pick exactly one upstream provider for the local SAI gateway.
# Start the gateway with:
#   sai gateway serve --host 127.0.0.1 --port 8787

# OpenAI
SAI_GATEWAY_PROVIDER=openai
OPENAI_API_KEY=

# OpenRouter
# SAI_GATEWAY_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=https://sponsoredai.dev
# OPENROUTER_APP_TITLE=SAI

# Groq
# SAI_GATEWAY_PROVIDER=groq
# GROQ_API_KEY=

# Mistral
# SAI_GATEWAY_PROVIDER=mistral
# MISTRAL_API_KEY=

# Together AI
# SAI_GATEWAY_PROVIDER=together
# TOGETHER_API_KEY=

# Fireworks AI
# SAI_GATEWAY_PROVIDER=fireworks
# FIREWORKS_API_KEY=

# DeepSeek
# SAI_GATEWAY_PROVIDER=deepseek
# DEEPSEEK_API_KEY=

# xAI
# SAI_GATEWAY_PROVIDER=xai
# XAI_API_KEY=

# Custom OpenAI-compatible upstream. This takes precedence over presets.
# SAI_UPSTREAM_BASE_URL=https://api.example.com/v1
# SAI_UPSTREAM_API_KEY=

# Local application logs. Defaults to SAI_HOME/logs/sai.log.
# SAI_LOG_LEVEL=INFO
# SAI_LOG_FILE=stderr
